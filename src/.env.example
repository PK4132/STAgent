# Example environment configuration for STAgent

# LM Studio local endpoint (used by Squidpy/SpatialData RAG pipeline)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=gemma4-e2b
LM_STUDIO_EMBEDDING_MODEL=nomic-embed-text-v1.5

# RAG code execution (execute node)
RAG_EXEC_ENABLED=true
RAG_EXEC_TIMEOUT=30
RAG_MAX_REWRITE_ATTEMPTS=3

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
# Optional OpenAI-compatible base URL override
OPENAI_API_BASE=
# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Google Gemini
GOOGLE_API_KEY=your-google-api-key-here
# Search and voice
SERP_API_KEY=your-serp-api-key-here
WHISPER_API_KEY=your-whisper-api-key-here
